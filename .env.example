DATABASE_PATH=./data/krypto.db
BASE_CURRENCY=EUR
PRICE_PROVIDER=coingecko
PRICE_CACHE_TTL_SECONDS=600
ALLOCATION_CONCENTRATION_WARNING_PERCENT=70
PUBLIC_APP_NAME=Krypto Dashboard
INTERNAL_CRON_SECRET=change-me-to-a-long-random-secret

# Use a long random INTERNAL_CRON_SECRET value in production.
# Keep /api/internal/* behind the bearer token and only expose the normal app route through Nginx Proxy Manager.
